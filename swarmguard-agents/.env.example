MONAD_RPC_URL=https://testnet-rpc.monad.xyz/
COORDINATOR_ADDRESS=0x...
VAULT_ADDRESS=0x...
ANTHROPIC_API_KEY=sk-ant-...

# Each private key must correspond to the wallet address passed into Coordinator's
# constructor at deploy time, in this exact order: [Flashloan, Oracle, Velocity, Wallet].
FLASHLOAN_AGENT_PRIVATE_KEY=0x...
ORACLE_AGENT_PRIVATE_KEY=0x...
VELOCITY_AGENT_PRIVATE_KEY=0x...
WALLET_AGENT_PRIVATE_KEY=0x...

# Optional: override the Claude model used for evaluation (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-sonnet-4-6
